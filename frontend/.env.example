# Backend API base URL — the Next.js rewrite proxy forwards /api/* here.
# Defaults to http://127.0.0.1:8000 if unset.
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# Frontend public origin. The browser should access both the web app and API from
# this same public origin via the reverse proxy.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Backend environment lives in backend/.env.example
