# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/csv

# Redis
REDIS_URL=redis://localhost:6379

# LLM Provider: "anthropic" or "openai" (openai protocol also works for DeepSeek, Qwen, etc.)
AI_PROVIDER=anthropic
AI_MODEL=claude-sonnet-4-20250514

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_BASE_URL=              # optional, for proxies

# OpenAI-compatible (used when AI_PROVIDER=openai)
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o                  # or deepseek-chat, qwen-max, etc.

# Embeddings (defaults to OpenAI if not set)
# EMBEDDING_API_KEY=               # defaults to OPENAI_API_KEY
# EMBEDDING_BASE_URL=              # defaults to OPENAI_BASE_URL
# EMBEDDING_MODEL=text-embedding-3-small

# Auth
JWT_SECRET=change-me-to-a-random-256-bit-string

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
